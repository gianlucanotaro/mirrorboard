# Encryption key for service credentials stored in MongoDB.
# Generate with: openssl rand -hex 32
# Store this value securely — never commit it. Keep a backup somewhere safe.
ENCRYPTION_KEY=

# MongoDB
# Local dev:  mongodb://localhost:27017
# Docker:     automatically set to mongodb://mongodb:27017 via docker-compose
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=mirrorboard

# Backend
PORT=8080

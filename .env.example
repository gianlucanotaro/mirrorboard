# Encryption key for service credentials stored in MongoDB.
# Generate with: openssl rand -hex 32
# Store this value securely — never commit it. Keep a backup somewhere safe.
ENCRYPTION_KEY=

# MongoDB
# Local dev:  mongodb://localhost:27017
# Docker:     automatically set to mongodb://mongodb:27017 via docker-compose
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=mirrorboard

# Google OAuth (for Calendar integration)
# Set up at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Weather (Open-Meteo — no API key needed)
WEATHER_LAT=47.3706
WEATHER_LON=8.0803
WEATHER_LOCATION=Suhr

# Backend
PORT=8080
